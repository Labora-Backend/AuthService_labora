# ==============================
# DJANGO
# ==============================
DJANGO_SECRET_KEY=change-this-to-a-long-random-django-secret-key
DEBUG=True


# ==============================
# JWT (RS256 – Microservice Safe)
# ==============================
JWT_ALGORITHM=RS256
JWT_PRIVATE_KEY_PATH=jwt_key/private.pem
JWT_PUBLIC_KEY_PATH=jwt_key/public.pem


# ==============================
# DATABASE
# ==============================
DB_NAME=microservices_db
DB_USER=root
DB_PASSWORD=1234
DB_HOST=localhost
DB_PORT=3306
